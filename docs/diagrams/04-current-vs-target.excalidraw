    { "id": "lsum_t", "type": "text", "x": 110, "y": 545, "width": 420, "height": 30, "angle": 0, "strokeColor": "#075985", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 2, "roughness": 0, "opacity": 100, "seed": 400041, "fontSize": 16, "fontFamily": 2, "textAlign": "center", "verticalAlign": "middle", "text": "summarize（模板字符串文案）", "containerId": "lsum", "updated": 1 },
    { "id": "lcon", "type": "text", "x": 110, "y": 620, "width": 420, "height": 100, "angle": 0, "strokeColor": "#991b1b", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 2, "roughness": 0, "opacity": 100, "seed": 400050, "fontSize": 15, "fontFamily": 2, "textAlign": "left", "verticalAlign": "top", "text": "痛点：\n• LLM_* 配置全闲置，token 恒为 0\n• 只懂大理/厦门，新城市质量差\n• special_notes 无法理解\n• graph.py 三套重复拓扑", "boundElements": null, "updated": 1 },

