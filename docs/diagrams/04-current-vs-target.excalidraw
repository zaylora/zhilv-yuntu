    { "id": "rllm", "type": "rectangle", "x": 700, "y": 160, "width": 250, "height": 230, "angle": 0, "strokeColor": "#6b21a8", "backgroundColor": "#f3e8ff", "fillStyle": "solid", "strokeWidth": 2, "roughness": 0, "opacity": 100, "seed": 400070, "boundElements": [{ "id": "rllm_t", "type": "text" }], "updated": 1 },
    { "id": "rllm_t", "type": "text", "x": 700, "y": 175, "width": 250, "height": 200, "angle": 0, "strokeColor": "#581c87", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 2, "roughness": 0, "opacity": 100, "seed": 400071, "fontSize": 16, "fontFamily": 2, "textAlign": "center", "verticalAlign": "middle", "text": "LLM 负责\n判断与表达\n\n• Coordinator 策略\n• Spot/Meal 语义筛选\n• Critic 评审\n• Narrator 文案", "containerId": "rllm", "updated": 1 },

