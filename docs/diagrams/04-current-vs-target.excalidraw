    { "id": "rmid_t", "type": "text", "x": 750, "y": 455, "width": 440, "height": 40, "angle": 0, "strokeColor": "#14532d", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 2, "roughness": 0, "opacity": 100, "seed": 400091, "fontSize": 16, "fontFamily": 2, "textAlign": "center", "verticalAlign": "middle", "text": "每个 LLM 节点：LLM 优先 + 规则兜底\n（无 key/超时/校验失败 → 自动降级）", "containerId": "rmid", "updated": 1 },

