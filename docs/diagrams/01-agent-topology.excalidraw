    { "id": "note", "type": "text", "x": 60, "y": 710, "width": 1150, "height": 44, "angle": 0, "strokeColor": "#64748b", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 2, "roughness": 0, "opacity": 100, "seed": 100300, "fontSize": 14, "fontFamily": 2, "textAlign": "left", "verticalAlign": "top", "text": "回环条件：Critic 判 revise 或 BudgetCheck 判超支，且 replan_count < TRIP_MAX_REPLAN（达上限强制 accept）。\nMealCurator 仅产城市级候选池，按当天区域就近选餐由 Scheduler 基于 day_centroids 完成。", "boundElements": null, "updated": 1 }
