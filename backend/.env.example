LLM_PROVIDER=openai_compatible
LLM_API_KEY=your_api_key_here
LLM_MODEL=qwen-max
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_TIMEOUT_SECONDS=60
LLM_MAX_RETRIES=1

# LangSmith 可观测性（LangGraph 节点追踪）
# 置为 true 才开启；为空或 false 时 agent 完全照常运行，不产生任何外部请求。
# 开启后在 https://smith.langchain.com 拿 API Key，每次行程生成/单日编辑的
# prompt、输出、token、延迟会自动上报，并按 outcome 标签区分 fallback。
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=your_langsmith_api_key
LANGCHAIN_PROJECT=zhilv-yuntu
# 默认即官方云端，一般无需修改：
# LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# Redis / Cache
REDIS_ENABLED=false
REDIS_URL=redis://127.0.0.1:6379/0
REDIS_KEY_PREFIX=trip_planner
REDIS_DEFAULT_TTL_SECONDS=1800
REDIS_WEATHER_TTL_SECONDS=1800
REDIS_MAP_TTL_SECONDS=86400

# Amap / Gaode Map
AMAP_API_KEY=your_amap_api_key
AMAP_BASE_URL=https://restapi.amap.com/v3
AMAP_DEFAULT_CITY=
AMAP_TIMEOUT_SECONDS=20
ENABLE_AMAP_ENRICHMENT=true

# Trip graph orchestration
USE_LANGGRAPH=true
TRIP_MAX_REPLAN=2
TRIP_SPOT_MIN_CANDIDATES=8
TRIP_SPOT_MAX_SEARCH_ROUNDS=2
TRIP_ENABLE_WEB_SEARCH=false
WEATHER_FORECAST_MAX_DAYS=4
TRIP_LOG_LEVEL=INFO
TRIP_METRICS_PERSIST=false
